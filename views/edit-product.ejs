<%- include('partials/header.ejs') %>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark"><h5>Edit Product</h5></div>
                <div class="card-body">
                    <form action="/product/edit/<%= product.id %>" method="POST" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label>Product Name</label>
                            <input type="text" name="name" value="<%= product.name %>" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label>Category</label>
                            <input type="text" name="category" value="<%= product.category %>" class="form-control" required>
                        </div>
                        <div class="row mb-3">
                            <div class="col">
                                <label>Price</label>
                                <input type="number" name="price" step="0.01" min="0" value="<%= product.price %>" class="form-control" required>
                            </div>
                            <div class="col">
                                <label>Stock</label>
                                <input type="number" name="stock" min="0" value="<%= product.stock %>" class="form-control" required>
                            </div>
                        </div>
                        <div class="mb-4">
                            <label>Product Image (Leave blank to keep current)</label>
                            <input type="file" name="image" class="form-control" accept="image/*">
                            <input type="hidden" name="old_image" value="<%= product.image %>">
                            <div class="mt-2 text-center">
                                <img src="/uploads/<%= product.image %>" width="100" class="img-thumbnail">
                            </div>
                        </div>
                        <div class="text-end">
                            <a href="/" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-success">Update Product</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer.ejs') %>